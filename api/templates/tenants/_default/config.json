{
  "slug": "_default",
  "displayName": "Sent Tech",
  "routeBase": "/",
  "brandUrl": "https://www.sent-tech.ca/",
  "themeKey": "tenants/_default/theme.css",
  "templateKey": "tenants/_default/template.docx",
  "templateContractVersion": "v1",
  "variant": "executive-modern",
  "active": true,
  "theme": {
    "primaryColor": "#1B4F98",
    "primaryDark": "#13386C",
    "accentColor": "#11C4D4",
    "accentHover": "#2BBDEE",
    "surfaceBorder": "#D8E8F6",
    "surfaceSubtle": "#F2F8FD",
    "fontHeading": "Poppins",
    "fontBody": "Inter",
    "borderRadius": "16px"
  },
  "branding": {
    "logoPath": "/SENT-logo.png",
    "faviconPath": "/SENT-logo-squared.svg",
    "subtitle": "Mise en forme de CV",
    "heroBackground": "linear-gradient(135deg, hsl(215 70% 25% / 0.9) 0%, hsl(215 60% 30% / 0.9) 50%, hsl(185 70% 40% / 0.9) 100%), url('/hero-tech.jpg') center/cover no-repeat",
    "shellBackground": "hsl(215 70% 25% / 0.95)"
  },
  "templateLibrary": {
    "enabled": true,
    "defaultVariant": "ats-core",
    "options": [
      {
        "id": "ats-core",
        "label": "Aether",
        "description": "Version ATS nette et structurée, conçue pour une lecture directe et sans surcharge.",
        "recommendedFor": "soumissions RH et filtrage automatique"
      },
      {
        "id": "professional-compact",
        "label": "Celestial",
        "description": "Sidebar douce et dense, sans photo, pour des profils expérimentés qui doivent rester compacts.",
        "recommendedFor": "profils seniors et conversions récurrentes"
      },
      {
        "id": "executive-modern",
        "label": "Horizon",
        "description": "Cadre plus éditorial et formel, avec une présence visuelle plus premium.",
        "recommendedFor": "avant-vente et profils de direction"
      },
      {
        "id": "consulting-classic",
        "label": "Solstice",
        "description": "Gabarit centré et classique, élégant sans être démonstratif, pour des propositions structurées.",
        "recommendedFor": "missions, conseil et réponses clients"
      },
      {
        "id": "brand-accent",
        "label": "Keystone",
        "description": "Bandeau fort et sidebar structurée, adaptés aux déclinaisons société avec accent de marque.",
        "recommendedFor": "pages société et déclinaisons tenant"
      }
    ]
  },
  "template": {
    "headerFields": {
      "namePlaceholder": "Candidate Name",
      "titleLine1Placeholder": "Senior Consultant",
      "titleLine2Placeholder": "Data, AI & Delivery",
      "yearsPlaceholder": "XX"
    },
    "sections": [
      "coreSkills",
      "sectorExperience",
      "experience",
      "languages",
      "education"
    ],
    "outputNaming": "SentTech_Profile_{name}.docx"
  },
  "templateContract": {
    "version": "v1",
    "layout": {
      "family": "single-column",
      "variant": "executive-modern"
    },
    "header": {
      "fields": [
        { "key": "name", "placeholder": "Candidate Name" },
        { "key": "headline", "placeholder": "Senior Consultant" },
        { "key": "subheadline", "placeholder": "Data, AI & Delivery" },
        { "key": "years_of_experience", "placeholder": "XX" }
      ],
      "limits": {
        "headlineMaxChars": 48,
        "subheadlineMaxChars": 48
      }
    },
    "sections": [
      { "key": "coreSkills", "label": "CORE SKILLS", "required": true, "repeatable": false },
      { "key": "sectorExperience", "label": "DOMAIN EXPERIENCE", "required": true, "repeatable": false },
      { "key": "experience", "label": "PROFESSIONAL EXPERIENCE", "required": true, "repeatable": true },
      { "key": "languages", "label": "LANGUAGES", "required": true, "repeatable": false },
      { "key": "education", "label": "EDUCATION & CERTIFICATIONS", "required": true, "repeatable": false }
    ],
    "styleTokens": {
      "colors": {
        "accent": "#11C4D4",
        "sectionBannerFill": "#EAF6FF",
        "sectionBannerText": "#13386C",
        "headingText": "#13386C",
        "bodyText": "#102132"
      },
    "fonts": {
      "heading": "Liberation Sans",
      "body": "Liberation Sans"
    },
      "spacing": {
        "sectionBeforeTwip": 260,
        "sectionAfterTwip": 200,
        "lineTwip": 300
      }
    },
    "output": {
      "filenamePattern": "SentTech_Profile_{name}.docx"
    }
  }
}
