{
  "slug": "_default",
  "displayName": "Sent Tech",
  "routeBase": "/",
  "brandUrl": "https://www.sent-tech.ca/",
  "themeKey": "tenants/_default/theme.css",
  "templateKey": "tenants/_default/template.docx",
  "templateContractVersion": "v1",
  "variant": "executive-modern",
  "active": true,
  "theme": {
    "primaryColor": "#1B4F98",
    "primaryDark": "#13386C",
    "accentColor": "#11C4D4",
    "accentHover": "#2BBDEE",
    "surfaceBorder": "#D8E8F6",
    "surfaceSubtle": "#F2F8FD",
    "fontHeading": "Poppins",
    "fontBody": "Inter",
    "borderRadius": "16px"
  },
  "branding": {
    "logoPath": "/SENT-logo.png",
    "faviconPath": "/SENT-logo-squared.svg",
    "subtitle": "Mise en forme de CV",
    "heroBackground": "linear-gradient(135deg, hsl(215 70% 25% / 0.9) 0%, hsl(215 60% 30% / 0.9) 50%, hsl(185 70% 40% / 0.9) 100%), url('/hero-tech.jpg') center/cover no-repeat",
    "shellBackground": "hsl(215 70% 25% / 0.95)"
  },
  "template": {
    "headerFields": {
      "namePlaceholder": "Candidate Name",
      "titleLine1Placeholder": "Senior Consultant",
      "titleLine2Placeholder": "Data, AI & Delivery",
      "yearsPlaceholder": "XX"
    },
    "sections": [
      "coreSkills",
      "sectorExperience",
      "experience",
      "languages",
      "education"
    ],
    "outputNaming": "SentTech_Profile_{name}.docx"
  },
  "templateContract": {
    "version": "v1",
    "layout": {
      "family": "single-column",
      "variant": "executive-modern"
    },
    "header": {
      "fields": [
        { "key": "name", "placeholder": "Candidate Name" },
        { "key": "headline", "placeholder": "Senior Consultant" },
        { "key": "subheadline", "placeholder": "Data, AI & Delivery" },
        { "key": "years_of_experience", "placeholder": "XX" }
      ],
      "limits": {
        "headlineMaxChars": 48,
        "subheadlineMaxChars": 48
      }
    },
    "sections": [
      { "key": "coreSkills", "label": "CORE STRENGTHS", "required": true, "repeatable": false },
      { "key": "sectorExperience", "label": "SECTOR EXPERIENCE", "required": true, "repeatable": false },
      { "key": "experience", "label": "PROFESSIONAL EXPERIENCE", "required": true, "repeatable": true },
      { "key": "languages", "label": "LANGUAGES", "required": true, "repeatable": false },
      { "key": "education", "label": "EDUCATION & CERTIFICATIONS", "required": true, "repeatable": false }
    ],
    "styleTokens": {
      "colors": {
        "accent": "#1E2B44",
        "sectionBannerFill": "#E9EEF5",
        "sectionBannerText": "#1E2B44",
        "headingText": "#1F2A38",
        "bodyText": "#243042",
        "mutedText": "#5B677A"
      },
      "fonts": {
        "heading": "Liberation Serif",
        "body": "Liberation Sans"
      },
      "spacing": {
        "sectionBeforeTwip": 220,
        "sectionAfterTwip": 120,
        "lineTwip": 290
      }
    },
    "rendering": {
      "headerStyle": "modern-band",
      "sectionStyle": "subtle-label",
      "jobStyle": "simple-balanced"
    },
    "output": {
      "filenamePattern": "SentTech_Profile_{name}.docx"
    }
  }
}
