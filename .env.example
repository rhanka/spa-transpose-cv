# ---------------------------
# LLM — set LLM_PROVIDER to one of: anthropic, openai, mistral, gemini, cohere
# Only the key for the selected provider is required.
# ---------------------------
export LLM_PROVIDER=mistral
export ANTHROPIC_API_KEY=sk-ant-...
# export OPENAI_API_KEY=sk-...
# export MISTRAL_API_KEY=...
# export GEMINI_API_KEY=...
# export COHERE_API_KEY=...

# ---------------------------
# Container registry (Scaleway)
# ---------------------------
export REGISTRY=rg.fr-par.scw.cloud/transpose-cv-reg
export DOCKER_USERNAME=nologin
export DOCKER_PASSWORD=<scw_secret_key>

# ---------------------------
# Scaleway
# ---------------------------
export SCW_DEFAULT_ORGANIZATION_ID=<uuid>
export SCW_DEFAULT_PROJECT_ID=<uuid>
export SCW_NAMESPACE_ID=<uuid>

# ---------------------------
# App config
# ---------------------------
export SESSION_MAX_AGE_HOURS=48
export MAX_CONCURRENT_AGENTS=5
export MAX_UPLOAD_SIZE_MB=50

# ---------------------------
# Tenant storage (Object Storage / SCW S3)
# ---------------------------
export TENANT_STORAGE_BACKEND=local
export TENANT_S3_BUCKET=cv-transpose-config
export TENANT_S3_REGION=fr-par
export TENANT_S3_ENDPOINT=https://s3.fr-par.scw.cloud
export TENANT_S3_ACCESS_KEY=<scw_access_key>
export TENANT_S3_SECRET_KEY=<scw_secret_key>
export TENANT_S3_PREFIX=

# ---------------------------
# Dev MinIO (docker-compose.dev)
# ---------------------------
export DEV_TENANT_STORAGE_BACKEND=s3
export DEV_TENANT_S3_BUCKET=cv-transpose-dev
export DEV_TENANT_S3_REGION=fr-par
export DEV_TENANT_S3_ENDPOINT=http://minio:9000
export MINIO_ROOT_USER=minioadmin
export MINIO_ROOT_PASSWORD=minioadmin
export MINIO_API_PORT=9000
export MINIO_CONSOLE_PORT=9001

# ---------------------------
# Admin DB-less auth
# ---------------------------
export ADMIN_PASSWORD_HASH=<generated_hex_hash>
export ADMIN_PASSWORD_SALT=<generated_hex_salt>
export ADMIN_SEED_SECRET=<long_random_secret>
export ADMIN_TOKEN_TTL_MINUTES=720
export ADMIN_OTP_TTL_MINUTES=15

# ---------------------------
# SMTP / Maildev
# ---------------------------
export SMTP_HOST=maildev
export SMTP_PORT=1025
export SMTP_SECURE=false
export SMTP_USER=
export SMTP_PASS=
export SMTP_FROM=cv-transpose@sent-tech.local
export MAILDEV_SMTP_PORT=1026
export MAILDEV_UI_PORT=1081
